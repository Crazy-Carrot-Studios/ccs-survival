    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.shelter.sleep
    displayName: Sleep in camp
    stepType: 58
    instructionText: Sleep at bedroll inside camp.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.shelter.verify.save
    displayName: Verify camp save/load
    stepType: 59
    instructionText: Save and load; camp tier and shelter should restore.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.homestead.buy.crate
    displayName: Buy Supply Crate kit
    stepType: 60
    instructionText: Press Ctrl+Shift+K to grant Supply Crate kit.
