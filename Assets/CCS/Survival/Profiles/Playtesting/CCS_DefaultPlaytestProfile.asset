    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.shelter.place.leanto
    displayName: Place Lean-To
    stepType: 54
    instructionText: Equip Lean-To kit and use twice to preview and place.
    targetItemId: ccs.survival.item.frontier.leantokit
