    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.workbench
    displayName: Craft item at workbench
    stepType: 13
    instructionText: Interact with CCS_TestWorkbench; F4 seeds mats; F3 crafts storage
