%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 073e3cf7aa6346e43816468ee0fe42c7, type: 3}
  m_Name: CCS_DefaultPlaytestProfile
  m_EditorClassIdentifier: CCS.Modules.Playtesting.Runtime::CCS.Modules.Playtesting.CCS_PlaytestProfile
  profileDisplayName: Default Playtest Harness
  profileId: ccs.survival.profile.playtesting.default
  profileDescription: Frontier starter progression with economy, hunting, and trapping
    playtest checklist for milestone 1.3.3.
  profileVersion: 1.3.3
  enableDebugLogs: 0
  enableHarness: 1
  showDebugLogs: 1
  resetStepStateOnPlayStart: 1
  stepDefinitions:
  - stepId: ccs.survival.playtest.spawn
    displayName: Spawn into bootstrap
    stepType: 0
    instructionText: Enter play mode in SCN_CCS_Survival_Bootstrap and confirm the
      player spawns.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.controller
    displayName: Third-person controller polish
    stepType: 16
    instructionText: Walk, sprint (Shift), rotate camera, interact (F), gather, press
      B for building preview, open storage (F2), and place/sleep at bedroll (Shift+F2).
      Step auto-completes when all are verified.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.gather
    displayName: Gather frontier resource
    stepType: 1
    instructionText: Gather fiber, sapling, stone, or scrap from CCS_TestFrontierTree,
      CCS_TestFrontierStoneOutcrop, or CCS_TestFrontierSalvageWagon (interact).
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.equip
    displayName: Equip pocket knife
    stepType: 2
    instructionText: Press F6 to equip the starter pocket knife (or equip manually
      when UI exists).
    targetItemId: ccs.survival.item.starter.knife
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.equipment.visual
    displayName: Confirm equipment visual
    stepType: 17
    instructionText: After equipping the pocket knife, confirm a placeholder visual
      appears on the player. Press F6 again to unequip and confirm the visual is
      removed.
    targetItemId: ccs.survival.item.starter.knife
    targetObjectId: 
    requiredCount: 2
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.active.select
    displayName: Select active item
    stepType: 18
    instructionText: Press F6 to equip pocket knife, then Alpha1 to select active
      item from main hand.
    targetItemId: ccs.survival.item.starter.knife
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.active.use
    displayName: Use active item
    stepType: 19
    instructionText: Primary attack (left mouse) routes through active item. Hit
      wildlife or receive a safe no-target result.
    targetItemId: ccs.survival.item.starter.knife
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.active.pick.rock
    displayName: Use pick on rock
    stepType: 21
    instructionText: Equip bone pick (Shift+F6), face CCS_TestGatheringRock, Alpha2
      active select, primary use.
    targetItemId: ccs.survival.item.tool.pick.bone
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.active.wrong.tool
    displayName: Wrong tool on gather target
    stepType: 22
    instructionText: Use pick on tree or hatchet on rock and confirm a safe WrongTool
      result (no error spam).
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.frontier.recipe.fishingpole
    displayName: Validate fishing pole recipe
    stepType: 25
    instructionText: Confirms frontier fishing pole recipe is registered on the crafting
      service (auto on step start).
    targetItemId: ccs.survival.recipe.frontier.fishingpole
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.frontier.recipe.bow
    displayName: Validate bow recipe
    stepType: 25
    instructionText: Confirms frontier bow recipe is registered (auto on step start).
      Optional ranged use remains unimplemented.
    targetItemId: ccs.survival.recipe.frontier.bow
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.fishing.equip
    displayName: Equip fishing pole
    stepType: 23
    instructionText: Shift+F6 while this step is active equips the primitive fishing
      pole.
    targetItemId: ccs.survival.item.tool.fishingpole
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.fishing.use
    displayName: Use fishing pole on spot
    stepType: 24
    instructionText: Face CCS_TestFishingSpot, Alpha2 select active pole, primary
      use. Catch fish or a valid nothing result.
    targetItemId: ccs.survival.item.tool.fishingpole
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.economy.fish.obtain
    displayName: Obtain fish for trade
    stepType: 27
    instructionText: Catch raw fish at CCS_TestFishingSpot or press F11 after fishing
      step grants inventory.
    targetItemId: ccs.survival.item.resource.rawfish
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.economy.store.interact
    displayName: Interact with general store
    stepType: 1
    instructionText: Face CCS_TestGeneralStore and interact (F) to open vendor debug.
      Press F11 when the vendor panel is visible.
    targetItemId: 
    targetObjectId: ccs.survival.vendor.frontier.generalstore
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.economy.fish.sell
    displayName: Sell fish at vendor
    stepType: 28
    instructionText: With vendor active, press Shift+V to sell one raw fish (or use
      vendor debug Sell).
    targetItemId: ccs.survival.item.resource.rawfish
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.economy.currency.verify.increase
    displayName: Verify currency increased
    stepType: 29
    instructionText: Confirm Trade Dollars balance increased after selling fish.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.economy.hatchet.buy
    displayName: Buy bone hatchet from vendor
    stepType: 30
    instructionText: 'Press H to buy the bone hatchet (first meaningful purchased
      tool). Vendor debug: Buy Hatchet.'
    targetItemId: ccs.survival.item.tool.hatchet.bone
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.economy.currency.verify.decrease
    displayName: Verify currency decreased
    stepType: 31
    instructionText: Confirm Trade Dollars were spent on the hatchet purchase.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.economy.hatchet.inventory
    displayName: Verify hatchet in inventory
    stepType: 32
    instructionText: Confirm bone hatchet appears in player inventory after purchase.
    targetItemId: ccs.survival.item.tool.hatchet.bone
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.economy.hatchet.equip
    displayName: Equip purchased hatchet
    stepType: 2
    instructionText: Shift+F6 equips the bone hatchet. Hatchet is not in the knife-only
      starter loadout.
    targetItemId: ccs.survival.item.tool.hatchet.bone
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.economy.hatchet.tree
    displayName: Use hatchet on tree
    stepType: 20
    instructionText: Face CCS_TestGatheringSmallTree, Alpha2 tool select, primary
      use to harvest wood.
    targetItemId: ccs.survival.item.tool.hatchet.bone
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.hunting.bow.obtain
    displayName: Obtain bow for hunt
    stepType: 33
    instructionText: Craft or grant the frontier bow (Shift+F6 debug or frontier
      bow recipe). Press F11 when bow is in inventory.
    targetItemId: ccs.survival.item.frontier.bow
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.hunting.bow.equip
    displayName: Equip bow for hunt
    stepType: 34
    instructionText: Shift+F6 equips the frontier bow for ranged hunting foundation
      verification.
    targetItemId: ccs.survival.item.frontier.bow
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.hunting.rabbit.kill
    displayName: Hunt rabbit with bow
    stepType: 3
    instructionText: Kill CCS_TestRabbit with primary attack while the bow is equipped.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.hunting.knife.equip
    displayName: Equip knife for harvest
    stepType: 2
    instructionText: Press F6 to equip the pocket knife before harvesting the carcass.
    targetItemId: ccs.survival.item.starter.knife
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.hunting.carcass.harvest
    displayName: Harvest rabbit carcass
    stepType: 4
    instructionText: Interact with the rabbit carcass and harvest skin/butcher drops
      with the knife equipped.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.hunting.hide.verify
    displayName: Verify hide in inventory
    stepType: 32
    instructionText: Confirm hide appears in player inventory after harvesting the
      rabbit carcass.
    targetItemId: ccs.survival.item.resource.hide
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.hunting.hide.sell
    displayName: Sell hide at vendor
    stepType: 35
    instructionText: Face CCS_TestGeneralStore, open vendor debug, and sell one hide
      (Shift+V or vendor Sell).
    targetItemId: ccs.survival.item.resource.hide
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.hunting.currency.verify
    displayName: Verify hunting currency increased
    stepType: 36
    instructionText: Confirm Trade Dollars balance increased after selling hide at
      the general store.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.trapping.trap.obtain
    displayName: Obtain simple trap
    stepType: 37
    instructionText: Craft simple trap or press Ctrl+Alt+T to grant one.
    targetItemId: ccs.survival.item.frontier.simpletrap
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.trapping.trap.equip
    displayName: Equip simple trap
    stepType: 38
    instructionText: Select the trap as active item (playtest harness).
    targetItemId: ccs.survival.item.frontier.simpletrap
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.trapping.trap.place
    displayName: Place simple trap
    stepType: 39
    instructionText: Primary use once for preview, again to confirm placement near
      CCS_TestRabbit.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.trapping.trigger
    displayName: Trigger trap capture
    stepType: 40
    instructionText: Wait for timer or press Alt+T to force capture roll near rabbit.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.trapping.harvest
    displayName: Harvest triggered trap
    stepType: 41
    instructionText: Equip knife (F6) and interact with the triggered trap.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.trapping.hide.verify
    displayName: Verify trap harvest inventory
    stepType: 42
    instructionText: Confirm hide is in inventory after trap harvest.
    targetItemId: ccs.survival.item.resource.hide
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.trapping.hide.sell
    displayName: Sell trap hide at vendor
    stepType: 43
    instructionText: Sell hide at general store (Shift+V on this step).
    targetItemId: ccs.survival.item.resource.hide
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.trapping.currency.verify
    displayName: Verify trapping currency increased
    stepType: 44
    instructionText: Confirm Trade Dollars increased after selling trap hide.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.hunt
    displayName: Hunt wildlife
    stepType: 3
    instructionText: Kill CCS_TestRabbit or CCS_TestDeer with primary attack while
      a weapon is equipped.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.spear.regression
    displayName: Equip spear (regression)
    stepType: 26
    instructionText: 'Optional legacy regression: press F6 on this step to equip
      the starter spear.'
    targetItemId: ccs.survival.item.starter.spear
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.harvest
    displayName: Harvest carcass
    stepType: 4
    instructionText: Harvest meat from the wildlife carcass.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.cook
    displayName: Cook meat at campfire
    stepType: 5
    instructionText: Cook raw meat at the test campfire station.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.eat
    displayName: Eat cooked meat
    stepType: 6
    instructionText: Press F to consume cooked rabbit or venison from inventory.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.shelter
    displayName: Build shelter
    stepType: 12
    instructionText: Place primitive foundation, at least one wall, and one roof
      (B places foundation; snap wall/roof).
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.workbench
    displayName: Craft item at workbench
    stepType: 13
    instructionText: Interact with CCS_TestWorkbench; F4 seeds mats; F3 crafts storage
      crate.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.storage
    displayName: Use storage crate
    stepType: 14
    instructionText: F2 place/open crate near player; F1 deposit item; F5 save; F9
      load to verify persistence.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.bedroll
    displayName: Place and sleep at bedroll
    stepType: 15
    instructionText: Shift+F2 place/sleep at bedroll; interact to sleep; F5 save;
      F9 load to verify bedroll restore.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.save
    displayName: Save game
    stepType: 8
    instructionText: Press F5 to save the unified survival file.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.load
    displayName: Load game
    stepType: 9
    instructionText: Press F9 to load the unified survival file.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.death
    displayName: Trigger death
    stepType: 10
    instructionText: Press F7 to drain needs or die from starvation/dehydration.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.respawn
    displayName: Respawn
    stepType: 11
    instructionText: Confirm respawn at the bootstrap respawn point.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
