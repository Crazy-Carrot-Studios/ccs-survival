    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.shelter.place.bedroll
    displayName: Place bedroll
    stepType: 56
    instructionText: Place bedroll within camp radius.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.shelter.verify.camp
    displayName: Verify TemporaryCamp
    stepType: 57
    instructionText: Camp tier should be TemporaryCamp when all three are nearby.
