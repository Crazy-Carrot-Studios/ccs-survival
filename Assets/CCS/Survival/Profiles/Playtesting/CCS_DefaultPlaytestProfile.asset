    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.bedroll
    displayName: Place and sleep at bedroll
    stepType: 15
    instructionText: Shift+F2 place/sleep at bedroll; interact to sleep; F5 save;
