    stepType: 64
    instructionText: Place workbench within camp radius.
    targetItemId: ccs.survival.item.frontier.workbenchkit
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.homestead.verify.homestead
    displayName: Verify FrontierHomestead
    stepType: 65
    instructionText: Camp tier should be FrontierHomestead.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.homestead.save
    displayName: Save homestead camp
    stepType: 66
    instructionText: Save game with homestead tier.
    targetItemId: 
    targetObjectId: 
    requiredCount: 1
