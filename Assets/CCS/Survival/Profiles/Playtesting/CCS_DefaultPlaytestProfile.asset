    targetItemId: 
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.storage
    displayName: Use storage crate
    stepType: 14
    instructionText: F2 place/open crate near player; F1 deposit item; F5 save; F9
