    stepType: 50
    instructionText: Press Ctrl+Shift+H to grant bone hatchet.
    targetItemId: ccs.survival.item.tool.hatchet.bone
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.shelter.wood
    displayName: Gather wood
    stepType: 51
    instructionText: Chop test tree with hatchet.
    targetItemId: ccs.survival.item.resource.wood
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.shelter.cordage
    displayName: Acquire cordage
    stepType: 52
    instructionText: Press Ctrl+Shift+C to grant cordage.
    targetItemId: ccs.survival.item.frontier.cordage
    targetObjectId: 
    requiredCount: 1
    timeoutSeconds: 0
  - stepId: ccs.survival.playtest.shelter.craft.leanto
    displayName: Craft Lean-To kit
    stepType: 53
    instructionText: Hand-craft Lean-To kit from wood, sapling, and cordage.
